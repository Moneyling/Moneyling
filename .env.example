# Stripe (payment page). Get keys from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Your backend URL that creates a PaymentIntent. It must:
# - Accept POST with JSON body: { amount (cents), currency, metadata?: { audience?, plan? } }
# - Return JSON: { clientSecret } (from stripe.paymentIntents.create)
VITE_STRIPE_CREATE_PAYMENT_INTENT_URL=https://your-api.com/create-payment-intent
